# ============================================================
# Rigup PRODUCTION env — copy to .env on the server
# ============================================================
#
# Split deploy (Vercel frontend + Railway API + Railway MySQL):
# - Vercel: REACT_APP_API_URL=https://<railway-api-host>/api
# - Railway (API service): DATABASE_URL = reference MySQL plugin MYSQL_URL, or paste URI
# - Railway CORS жишээ (pcpeak): FRONTEND_URL=https://pcpeak.vercel.app
#   ба/эсвэл CORS_ORIGINS=https://pcpeak-git-main-khusleecs-projects.vercel.app,https://pcpeak-hdolvzr9v-khusleecs-projects.vercel.app
# - Эсвэл FRONTEND_URL-д гурвыг коммаар нэг мөрөнд (бүгд зөвшөөрөгдөнө)
# - Railway (API): TRUST_PROXY=true, NODE_ENV=production, JWT_SECRET (32+ chars)
# - Optional: inferred *.vercel.app CORS — хэрэв FRONTEND_URL-д *.vercel.app байвал preview-ууд автоматаар (core-api код)
# - Google нэвтрэлт: Firebase — REACT_APP_FIREBASE_* + core-api Firebase Admin (backend/core-api/.env.example)

# Your domain (without https://). Caddy uses this for SSL.
DOMAIN=rigup.example.com

# ─── MySQL (internal only — no public port) ────────────────
MYSQL_DATABASE=rigup
MYSQL_USER=rigup
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONGER_ROOT
DATABASE_URL=mysql://rigup:CHANGE_ME_STRONG_PASSWORD@mysql:3306/rigup

# ─── core-api ──────────────────────────────────────────────
# MUST be at least 32 chars in production. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX_STRING_HERE_PLEASE
JWT_EXPIRES_IN=7d

# Railway core-api CORS ↔ Vercel (pcpeak) — uncomment & paste на Railway Variables
# FRONTEND_URL=https://pcpeak.vercel.app
# CORS_ORIGINS=https://pcpeak-git-main-khusleecs-projects.vercel.app,https://pcpeak-hdolvzr9v-khusleecs-projects.vercel.app

# ─── AI ────────────────────────────────────────────────────
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# ─── Google Maps (optional) ────────────────────────────────
REACT_APP_GOOGLE_MAPS_API_KEY=

# ─── Payments ──────────────────────────────────────────────
# Demo mode (no real money) — flip to false when QPAY_* below are set.
PAYMENTS_DEMO_MODE=true

QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_INVOICE_CODE=
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_BRANCH_CODE=ONLINE
QPAY_RECEIVER_CODE=terminal
QPAY_EBARIMT_ENABLED=false
QPAY_EBARIMT_RECEIVER_TYPE=CITIZEN

# ─── Firebase Auth (optional — Google via Firebase) ─────────
# Frontend: REACT_APP_FIREBASE_*  |  API: FIREBASE_SERVICE_ACCOUNT_PATH or env from backend/core-api/.env.example
# FIREBASE_SERVICE_ACCOUNT_PATH=
