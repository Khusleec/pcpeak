# Optional: force API host. If unset on Vercel, the app uses same-origin /api
# (see frontend/vercel.json rewrite to Railway).
# Local docker-compose (default port 5500):
# REACT_APP_API_URL=http://localhost:5500/api
# Or leave unset → defaults to http://localhost:5500/api in dev.
#
# Explicit production (bypasses Vercel proxy):
# REACT_APP_API_URL=https://YOUR-SERVICE.up.railway.app/api

# ─── Firebase (optional) ─────────────────────────────────
# Copy values from Firebase console → Project settings → Your apps → Web app.
# If any required field is blank, Firebase is skipped (no crash).
# REACT_APP_FIREBASE_API_KEY=
# REACT_APP_FIREBASE_AUTH_DOMAIN=
# REACT_APP_FIREBASE_PROJECT_ID=
# REACT_APP_FIREBASE_STORAGE_BUCKET=
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
# REACT_APP_FIREBASE_APP_ID=
# REACT_APP_FIREBASE_MEASUREMENT_ID=
