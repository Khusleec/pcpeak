# Caddy reverse proxy with auto Let's Encrypt SSL
# Replace {$DOMAIN} via environment variable in docker-compose.prod.yml
+
{$DOMAIN} {
    encode gzip zstd

    # Backend API → core-api:4000
    handle /api/* {
        reverse_proxy core-api:4000
    }

    # Everything else → frontend (nginx serving React build)
    handle {
        reverse_proxy frontend:80
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output stdout
        format json
    }
}
