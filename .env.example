# ─── MySQL ─────────────────────────────────────────────
MYSQL_DATABASE=rigup
MYSQL_USER=rigup
MYSQL_PASSWORD=change_me_db
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PORT=33306

# Connection string used by core-api + agent-worker (host=mysql inside compose)
DATABASE_URL=mysql://rigup:change_me_db@mysql:3306/rigup

# ─── core-api ──────────────────────────────────────────
CORE_API_PORT=5500
JWT_SECRET=replace_with_at_least_32_random_characters_please
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
TRUST_PROXY=false

# AGENT_CHAT_ASYNC_ONLY=true — enqueue chat then return 202 immediately (no long POST). Required on some hosts (Railway auto-enables when RAILWAY_ENVIRONMENT is set).
# AGENT_CHAT_ASYNC_ONLY=false — restore long-poll on POST until reply or timeout (fine on Docker LAN).

# Long-poll window for /api/agent/chat (ms). Raise if LLM is consistently slow.
AGENT_RESPONSE_TIMEOUT_MS=45000
# How often core-api re-reads agent_tasks while waiting (lower = snappier, more DB reads).
AGENT_POLL_INTERVAL_MS=250

# ─── agent-worker ──────────────────────────────────────
# How often the worker polls for new queued tasks (lower = faster pickup, slightly more CPU).
AGENT_WORKER_POLL_INTERVAL_MS=250
AGENT_MAX_TOOL_ROUNDS=8
# auto = DB tools only when message looks booking-related (natural chat). always = old behaviour.
# AGENT_BOOKING_TOOLS_MODE=always

# AI provider (Groq-compatible OpenAI API by default).
# Leave AI_API_KEY blank to disable the AI assistant — chat will return an error.
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
# 70b = smarter/slower; try llama-3.1-8b-instant on Groq for faster replies.
AI_MODEL=llama-3.3-70b-versatile

# ─── frontend ──────────────────────────────────────────
FRONTEND_PORT=5173
REACT_APP_API_URL=http://localhost:5500/api

# Optional Google Maps key (offline simulation works without it)
REACT_APP_GOOGLE_MAPS_API_KEY=

# ─── QPay (optional payment provider) ──────────────────
# Leave blank to use local payment simulation.
# PAYMENTS_DEMO_MODE=true — pending_payment + demo invoice without QPAY_* (Docker compose defaults to true).
# Set false when you configure real QPay below.
# PAYMENTS_DEMO_MODE=false
# QPAY_BASE_URL=https://merchant.qpay.mn
# QPAY_CLIENT_ID=
# QPAY_CLIENT_SECRET=
# QPAY_USERNAME=
# QPAY_PASSWORD=
# QPAY_INVOICE_CODE=
# QPAY_BRANCH_CODE=ONLINE
# QPAY_RECEIVER_CODE=terminal
# QPAY_PUBLIC_BASE_URL=
# QPAY_CALLBACK_SECRET=
# After payment: POST https://merchant.qpay.mn/v2/ebarimt/create (E-barimt 3.0). Off by default.
# QPAY_EBARIMT_ENABLED=false
# QPAY_EBARIMT_RECEIVER_TYPE=CITIZEN

# Dev / demo: fake “paid” for pending bookings (also when PAYMENTS_DEMO_MODE=true in any NODE_ENV)
# ALLOW_SIMULATE_PAYMENT=true
