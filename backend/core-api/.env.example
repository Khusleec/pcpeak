# Server
PORT=4000
NODE_ENV=development

# MySQL (mysql2 URI). Example local:
# DATABASE_URL=mysql://mongolpc:secret@localhost:3306/mongolpc
DATABASE_URL=

# Trust X-Forwarded-For when behind Nginx Ingress / reverse proxy (production)
TRUST_PROXY=false

JWT_SECRET=dev-change-me-never-use-in-production
JWT_EXPIRES_IN=7d

# Frontend URL(s) — comma-separated; each is an allowed CORS origin (scheme + host, no path)
# Local: http://localhost:3000
# ─── pcpeak @ Vercel (жишээ — Railway-д core-api Variables-д хуулаарай, https заавал) ───
# Prod: FRONTEND_URL=https://pcpeak.vercel.app
# Branch preview + deployment preview (нэмэлтээс нэг дор):
# CORS_ORIGINS=https://pcpeak-git-main-khusleecs-projects.vercel.app,https://pcpeak-hdolvzr9v-khusleecs-projects.vercel.app
# Эсвэл бүх галыг коммаар FRONTEND_URL-д:
# FRONTEND_URL=https://pcpeak.vercel.app,https://pcpeak-git-main-khusleecs-projects.vercel.app,https://pcpeak-hdolvzr9v-khusleecs-projects.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional: extra CORS origins when FRONTEND_URL is prod only — шинэ preview нэмэгдвэл эндээс нэм
# CORS_ORIGINS=https://pcpeak-git-main-khusleecs-projects.vercel.app,https://pcpeak-hdolvzr9v-khusleecs-projects.vercel.app

# Optional: allow any https://*.vercel.app (only needed if FRONTEND_URL has no *.vercel.app entry, e.g. custom domain only)
# Explicit off: CORS_ALLOW_VERCEL=false — disables even inferred preview access
# CORS_ALLOW_VERCEL=true

# QPay Merchant API v2 (optional). When enabled, new bookings are pending_payment until 30% deposit is paid.
# Without QPay keys, set PAYMENTS_DEMO_MODE=true for the same pending flow + demo invoice (see root .env.example).
# Use either CLIENT_ID + CLIENT_SECRET or USERNAME + PASSWORD (QPay portal labels vary; both are Basic auth).
# QPAY_PUBLIC_BASE_URL must be the public HTTPS base of this API (QPay callback).
# Sandbox base URL (from QPay docs): https://merchant-sandbox.qpay.mn — set QPAY_BASE_URL when testing sandbox.
# E-barimt 3.0: after a payment is confirmed, core-api can POST /v2/ebarimt/create (optional).
# QPAY_EBARIMT_ENABLED=false
# QPAY_EBARIMT_RECEIVER_TYPE=CITIZEN
# QPAY_BASE_URL=https://merchant.qpay.mn
# QPAY_CLIENT_ID=
# QPAY_CLIENT_SECRET=
# QPAY_USERNAME=
# QPAY_PASSWORD=
# QPAY_INVOICE_CODE=
# QPAY_BRANCH_CODE=ONLINE
# QPAY_RECEIVER_CODE=terminal
# QPAY_PUBLIC_BASE_URL=https://your-api.example.com
# QPAY_CALLBACK_SECRET=

# PAYMENTS_DEMO_MODE=true — pending_payment + demo invoice (no QPay API). Confirm via POST /api/payments/simulate/bookings/:id
# PAYMENTS_DEMO_MODE=false

# ALLOW_SIMULATE_PAYMENT=true — same simulate endpoint; in production only works if PAYMENTS_DEMO_MODE=true
# AI agent — prefer AI_* keys. Fallbacks OPENAI_* are still read if AI_* unset.
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Compatibility aliases (optional; used only if AI_* missing)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# App rate limiting (Ingress may also enforce limits — tune both consciously)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
