{
  "name": "mongolpc-backend",
  "version": "1.0.0",
  "description": "Mongol PC Cafe Booking System - Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:with-db": "node src/db/init.js && node src/db/migrate.js && node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint .",
    "test": "jest tests/health.test.js --runInBand --forceExit",
    "test:integration": "jest tests/smoke.integration.test.js --runInBand --forceExit",
    "db:init": "node src/db/init.js",
    "db:seed": "node src/db/seed.js",
    "db:migrate": "node src/db/migrate.js"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/setup-env.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.0.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.3",
    "openai": "^4.20.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
